{
  "name": "vue-ascii-overlay",
  "version": "0.1.0",
  "description": "A Vue 3 component that renders an interactive ASCII character overlay with mouse-driven Navier-Stokes fluid simulation.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/ascii-overlay.cjs",
  "module": "./dist/ascii-overlay.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/ascii-overlay.mjs",
      "require": "./dist/ascii-overlay.cjs",
      "style": "./dist/vue-ascii-overlay.css"
    },
    "./style.css": "./dist/vue-ascii-overlay.css"
  },
  "style": "./dist/vue-ascii-overlay.css",
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "keywords": [
    "vue",
    "vue3",
    "ascii",
    "overlay",
    "fluid-simulation",
    "navier-stokes",
    "canvas",
    "interactive",
    "component"
  ],
  "license": "MIT",
  "author": "Nick Tagliasacchi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notTag/vue-ascii-overlay.git"
  }
}
